{
  "openapi": "3.0.0",
  "info": {
    "title": "CCIC Public API",
    "version": "1.0.0",
    "description": "Public API endpoints for colleges, courses, exams, blogs, news, and more. No authentication required."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current server"
    }
  ],
  "tags": [
    {
      "name": "Colleges",
      "description": "College listings and details"
    },
    {
      "name": "Courses",
      "description": "Course listings and details"
    },
    {
      "name": "Exams",
      "description": "Exam listings"
    },
    {
      "name": "Blogs",
      "description": "Blog posts"
    },
    {
      "name": "News",
      "description": "News articles"
    },
    {
      "name": "Notices",
      "description": "Notices and announcements"
    },
    {
      "name": "Pages",
      "description": "CMS pages"
    },
    {
      "name": "Reviews",
      "description": "College reviews and replies"
    },
    {
      "name": "Search",
      "description": "Global search"
    },
    {
      "name": "Misc",
      "description": "States, testimonials, footer, facilities"
    }
  ],
  "components": {
    "schemas": {
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "object"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "security": [],
  "paths": {
    "/api/public/colleges": {
      "get": {
        "tags": [
          "Colleges"
        ],
        "summary": "Get colleges for public pages",
        "description": "Returns active colleges with optional featured, popular, or top filters. Supports country → state → district cascading filters.",
        "parameters": [
          {
            "in": "query",
            "name": "country",
            "schema": {
              "type": "string"
            },
            "description": "Filter by country MongoDB ObjectId"
          },
          {
            "in": "query",
            "name": "state",
            "schema": {
              "type": "string"
            },
            "description": "Filter by state MongoDB ObjectId"
          },
          {
            "in": "query",
            "name": "district",
            "schema": {
              "type": "string"
            },
            "description": "Filter by district MongoDB ObjectId"
          },
          {
            "in": "query",
            "name": "featured",
            "schema": {
              "type": "string",
              "enum": [
                true,
                false
              ]
            }
          },
          {
            "in": "query",
            "name": "popular",
            "schema": {
              "type": "string",
              "enum": [
                true,
                false
              ]
            }
          },
          {
            "in": "query",
            "name": "top",
            "schema": {
              "type": "string",
              "enum": [
                true,
                false
              ]
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer",
              "default": 6
            }
          },
          {
            "in": "query",
            "name": "count",
            "schema": {
              "type": "string",
              "enum": [
                true
              ]
            },
            "description": "Return total count only"
          }
        ],
        "responses": {
          "200": {
            "description": "Colleges list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/api/public/colleges-listing": {
      "get": {
        "tags": [
          "Colleges"
        ],
        "summary": "Paginated college listing with filters",
        "parameters": [
          {
            "in": "query",
            "name": "country",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "state",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "district",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "page",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "in": "query",
            "name": "search",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "city",
            "schema": {
              "type": "string"
            },
            "description": "Filter by district/city name (scoped by country and state when provided)"
          },
          {
            "in": "query",
            "name": "ownership",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "exam",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "course",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "feeRange",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "sortBy",
            "schema": {
              "type": "string",
              "enum": [
                "alphabetical",
                "popularity",
                "fees_low_to_high"
              ],
              "default": "alphabetical"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated colleges"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
