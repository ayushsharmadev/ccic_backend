    "/api/public/reviews/{collegeSlug}": {
      "get": {
        "tags": [
          "Reviews"
        ],
        "summary": "Get approved reviews for a college",
        "parameters": [
          {
            "in": "path",
            "name": "collegeSlug",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "page",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Reviews list with pagination"
          },
          "404": {
            "description": "College not found"
          },
          "500": {
            "description": "Server error"
          }
        }
      },
      "post": {
        "tags": [
          "Reviews"
        ],
        "summary": "Submit a college review",
        "parameters": [
          {
            "in": "path",
            "name": "collegeSlug",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "rating",
                  "comment"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "mobile": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "rating": {
                    "type": "number",
                    "minimum": 1,
                    "maximum": 5
                  },
                  "comment": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Review submitted (pending approval)"
          },
          "400": {
            "description": "Validation error"
          },
          "404": {
            "description": "College not found"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/api/public/reviews/{collegeSlug}/reply": {
      "post": {
        "tags": [
          "Reviews"
        ],
        "summary": "Submit a reply to a review",
        "parameters": [
          {
            "in": "path",
            "name": "collegeSlug",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "reviewId",
                  "name",
                  "comment"
                ],
                "properties": {
                  "reviewId": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "mobile": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "comment": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reply submitted (pending approval)"
          },
          "400": {
